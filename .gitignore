# ============================================================
#  Project sty — .gitignore
# ============================================================

# ── Compiled Binaries & Object Files ────────────────────────
*.exe
*.dll
*.obj
*.o
*.a
*.lib
*.pdb          # Program database (debug symbols)
*.ilk          # Incremental linker files
*.exp

# ── Build Directories ────────────────────────────────────────
/build/
/out/
/cmake-build-*/
/_build/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile        # Generated by CMake (not the hand-written one)

# ── Compiled Project Executable ──────────────────────────────
/ArrangerEngine.exe

# ── Yamaha Style / Preset Data Files ─────────────────────────
# Large binary assets — load them locally, don't track in git
/Ballad1/
/Ballroom1/
*.sty
*.prs
*.prs.bk
*.bk
LoveSong.S687.prs.bk

# ── Scratch / Temp Directories ───────────────────────────────
/scratch/
/tmp/
*.tmp
*.log

# ── Visual Studio / MSVC ─────────────────────────────────────
.vs/
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.sln
*.suo
*.user
*.aps
*.ncb
*.sdf
*.opensdf
ipch/

# ── VS Code ──────────────────────────────────────────────────
.vscode/

# ── Windows OS Files ─────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ── CMake FetchContent / External Deps Cache ─────────────────
# If you prefer to vendor rtmidi via git submodule instead,
# remove the line below and run: git submodule add <url> vendor/rtmidi
/vendor/rtmidi/

# ── Misc ─────────────────────────────────────────────────────
*.bak
*.orig
*.swp
*~